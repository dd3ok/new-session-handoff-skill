{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/new-session-handoff/handoff-automation-v1.schema.json",
  "title": "Handoff Automation V1 Marker Values",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "HANDOFF_READY",
    "HANDOFF_SCHEMA_VERSION",
    "HANDOFF_MODE",
    "DETAIL_ARTIFACTS_READY",
    "NEW_SESSION_PROMPT_READY",
    "DISK_STATE_RECORDED",
    "VALIDATION_RECORDED",
    "SECRET_REDACTION_CHECKED",
    "SAFE_FOR_NEW_SESSION",
    "BLOCKERS"
  ],
  "properties": {
    "HANDOFF_READY": {
      "type": "string",
      "minLength": 1
    },
    "HANDOFF_SCHEMA_VERSION": {
      "const": "1"
    },
    "HANDOFF_MODE": {
      "enum": ["compact", "expanded", "prompt-only"]
    },
    "DETAIL_ARTIFACTS_READY": {
      "enum": ["yes", "no", "not-needed"]
    },
    "NEW_SESSION_PROMPT_READY": {
      "enum": ["yes", "no"]
    },
    "DISK_STATE_RECORDED": {
      "enum": ["yes", "no"]
    },
    "VALIDATION_RECORDED": {
      "enum": ["yes", "no"]
    },
    "SECRET_REDACTION_CHECKED": {
      "enum": ["yes", "no"]
    },
    "SAFE_FOR_NEW_SESSION": {
      "enum": ["yes", "no"]
    },
    "BLOCKERS": {
      "type": "string",
      "minLength": 1
    }
  }
}
